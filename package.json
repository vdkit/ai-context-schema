{
  "name": "@vdkit/ai-context-schema",
  "version": "3.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Universal schema for defining AI assistant behavior across development platforms",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vdkit/ai-context-schema.git"
  },
  "author": "AI Context Schema Contributors",
  "homepage": "https://github.com/vdkit/ai-context-schema#readme",
  "bugs": {
    "url": "https://github.com/vdkit/ai-context-schema/issues"
  },
  "main": "validation/schema-validator.js",
  "bin": {
    "ai-context-schema": "validation/schema-validator.js"
  },
  "exports": {
    ".": "./validation/schema-validator.js",
    "./schemas/vdk/blueprint-schema.json": "./schemas/vdk/blueprint-schema.json",
    "./schemas/vdk/command-schema.json": "./schemas/vdk/command-schema.json",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "check": "pnpm run lint:all && pnpm run test && pnpm run validate-all",
    "check-compatibility": "node validation/compatibility-checker.js schemas/v3.0.0/examples",
    "ci": "pnpm run check",
    "docs:serve": "markdownlint-cli2 'docs/**/*.md' 'implementations/**/*.md' 'schemas/**/*.md' '*.md' && echo 'Documentation validated'",
    "fix:all": "pnpm run lint:fix && pnpm run format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --import-plugin -c .oxlintrc.json \"lint/blueprint-lint-trigger.mjs\"",
    "lint:all": "pnpm run lint && pnpm run format:check && pnpm run lint:docs",
    "lint:blueprints:dry": "vdk-blueprints-fix --target schemas/v3.0.0/examples",
    "lint:blueprints:fix": "vdk-blueprints-fix --write --target schemas/v3.0.0/examples",
    "lint:docs": "markdownlint-cli2 'docs/**/*.md' 'implementations/**/*.md' 'schemas/**/*.md' '*.md'",
    "lint:fix": "pnpm run lint:blueprints:fix && pnpm run lint",
    "lint:js": "oxlint --import-plugin -c .oxlintrc.json \"lint/blueprint-lint-trigger.mjs\"",
    "prepare": "husky",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "validate": "node validation/schema-validator.js",
    "validate-all": "node validation/schema-validator.js schemas/v3.0.0/examples --warnings",
    "validate-verbose": "node validation/schema-validator.js schemas/v3.0.0/examples --verbose --warnings"
  },
  "files": [
    "CONTRIBUTING.md",
    "docs/",
    "implementations/",
    "schemas/",
    "SPECIFICATION.md",
    "validation/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "artificial-intelligence",
    "context",
    "schema",
    "coding-assistant",
    "claude",
    "cursor",
    "windsurf",
    "github-copilot",
    "development",
    "standardization"
  ],
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@vdkit/oxlint-plugin-blueprints": "^1.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "oxlint": "^1.51.0",
    "rimraf": "^6.1.3",
    "yaml-lint": "^1.7.0"
  },
  "directories": {
    "doc": "docs",
    "example": "schemas/v3.0.0/examples"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ai-context-schema"
  }
}
